{
  "name": "it_dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "worker": "tsx watch worker/index.ts",
    "dev:all": "concurrently -n next,worker -c blue,green \"npm run dev\" \"npm run worker\"",
    "build": "next build",
    "start": "next start",
    "start:all": "concurrently -n next,worker -c blue,green \"next start\" \"tsx worker/index.ts\"",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "create-user": "tsx scripts/create-user.ts",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:integration": "jest --config jest.integration.config.ts --forceExit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "migrate:credentials": "tsx scripts/migrate-credentials.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/net-snmp": "^3.23.0",
    "@types/ping": "^0.4.4",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "html2pdf.js": "^0.14.0",
    "lru-cache": "^11.5.1",
    "lucide-react": "^1.17.0",
    "net-snmp": "^3.26.3",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "otplib": "^13.4.1",
    "pg": "^8.21.0",
    "ping": "^1.0.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.77.0",
    "recharts": "^3.8.1",
    "routeros": "^1.6.12",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/html2pdf.js": "^0.10.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jest": "^30.4.2",
