# Banco de dados PostgreSQL
# Para desenvolvimento local com Docker: docker compose up -d
DATABASE_URL="postgresql://it_dashboard:it_dashboard@localhost:5432/it_dashboard"

# NextAuth
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Webhook — token HMAC-SHA256 para endpoints up/down de links
# Gerar com: openssl rand -hex 32
WEBHOOK_SECRET="change-me"

# Criptografia de credenciais RouterOS (AES-256-GCM, 32 bytes = 64 chars hex)
# Gerar com: openssl rand -hex 32
ENCRYPTION_KEY="change-me"
