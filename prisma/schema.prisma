generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum DeviceType {
  MIKROTIK
  DVR
  CAMERA
  OTHER
  UNIFI_AP
  OMADA_AP
}

model Device {
  id       String     @id @default(cuid())
  name     String
  ip       String
  type     DeviceType
  location String?
  notes    String?

  pingEnabled     Boolean @default(true)
  httpEnabled     Boolean @default(false)
  httpPort        Int?
  httpPath        String  @default("/")
  snmpEnabled       Boolean @default(false)
  snmpCommunity     String  @default("public") // plaintext fallback for existing records
  snmpCommunityEnc  String? // AES-256-GCM encrypted
  snmpPort          Int     @default(161)
  routerosEnabled Boolean @default(false)
  routerosUserEnc String? // AES-256-GCM encrypted
  routerosPassEnc String? // AES-256-GCM encrypted
  routerosPort    Int     @default(8728)

  unifiEnabled      Boolean @default(false)
  unifiAuthMethod   String  @default("apikey") // "apikey" | "userpass"
  unifiApiKeyEnc    String? // AES-256-GCM encrypted API key (X-API-KEY)
  unifiUserEnc      String? // AES-256-GCM encrypted username (inform API)
  unifiPassEnc      String? // AES-256-GCM encrypted password (inform API)
  unifiPort         Int     @default(443)
  unifiSite         String  @default("default")
  unifiTlsVerify    Boolean @default(true)
  unifiControllerIp String? // null = usar o próprio IP do dispositivo (UDM/standalone)

  omadaEnabled         Boolean @default(false)
  omadaClientIdEnc     String? // AES-256-GCM encrypted OAuth2 client_id
  omadaClientSecretEnc String? // AES-256-GCM encrypted OAuth2 client_secret
  omadacId             String? // Omada Controller omadacId (descoberto via API)
  omadaSite            String? // nome do site (display)
  omadaSiteId          String? // ID do site na API (lookup direto, sem iterar sites)
  omadaTlsVerify       Boolean @default(true)
  omadaControllerIp    String? // IP do Omada Controller

  checkInterval Int @default(60)

  // Alert notifications
  alertWebhookUrl String?
  alertThreshold  Int      @default(3) // consecutive failures before firing alert
  lastAlertAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  currentStatus  DeviceStatus?
  history        StatusHistory[]
  noteItems      Note[]
  monitoredLinks Link[]          @relation("LinkMikrotik")
}

model DeviceStatus {
  id       String @id @default(cuid())
  deviceId String @unique
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  isOnline   Boolean  @default(false)
  pingMs     Int?
  httpOk     Boolean?
  uptime     Int?
  cpuLoad    Float?
  memoryUsed Float?
  routerosData Json?
  unifiData    Json?
  unifiError   String?
  omadaData    Json?
  omadaError   String?

  checkedAt DateTime @default(now())
}

model StatusHistory {
  id       String @id @default(cuid())
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  isOnline   Boolean
  pingMs     Int?
  cpuLoad    Float?
  memoryUsed Float?

  timestamp DateTime @default(now())

  @@index([deviceId, timestamp])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  OPERADOR
  VIEWER
}

enum LinkEventType {
  UP
  DOWN
}

model Link {
  id          String      @id @default(cuid())
  name        String
  description String?
  location    String?
  isOnline    Boolean     @default(true)
  lastEventAt DateTime?

  // RouterOS traffic monitoring config
  mikrotikDeviceId  String?
  mikrotikInterface String?

  // Contracted bandwidth (configured manually, in bps)
  contractedDownloadBps Int?
  contractedUploadBps   Int?

  // Latest traffic stats (updated by worker)
  downloadBps Int?
  uploadBps   Int?
  latencyMs   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mikrotikDevice Device?    @relation("LinkMikrotik", fields: [mikrotikDeviceId], references: [id], onDelete: SetNull)
  events         LinkEvent[]
}

model LinkEvent {
  id        String        @id @default(cuid())
  linkId    String
  link      Link          @relation(fields: [linkId], references: [id], onDelete: Cascade)
  type      LinkEventType
  timestamp DateTime      @default(now())

  @@index([linkId, timestamp])
}

enum NoteSeverity {
  INFO
  WARNING
  HIGH
  CRITICAL
}

enum NoteCategory {
  SECURITY
  OPERATIONAL
  GENERAL
}

enum NoteStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model WorkerHeartbeat {
  id     Int      @id @default(1) // singleton — only one row ever
  seenAt DateTime @updatedAt
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGIN_FAILED
  CLEANUP
}

model AuditLog {
  id         String      @id @default(cuid())
  timestamp  DateTime    @default(now())
  userId     String?
  username   String?
  ipAddress  String?
  action     AuditAction
  entity     String
  entityId   String?
  entityName String?
  details    Json?

  @@index([timestamp])
  @@index([entity, timestamp])
  @@index([userId, timestamp])
}

model SystemConfig {
  id                  Int      @id @default(1) // singleton
  statusHistoryDays   Int      @default(30)
  linkEventDays       Int      @default(90)
  lastCleanupAt       DateTime?
  updatedAt           DateTime @updatedAt
}

model RateLimit {
  ip        String   @id
  count     Int      @default(1)
  resetAt   DateTime

  @@index([resetAt])
}

model Note {
  id         String       @id @default(cuid())
  title      String
  content    String
  severity   NoteSeverity @default(INFO)
  category   NoteCategory @default(GENERAL)
  status     NoteStatus   @default(OPEN)
  deviceId   String?
  device     Device?      @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  resolvedAt DateTime?
}
